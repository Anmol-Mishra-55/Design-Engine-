# Environment Configuration Template
# Copy this to .env and fill in your actual values

# Application Settings
DEBUG=false
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000

# MongoDB Configuration (REQUIRED)
MONGODB_URL=mongodb+srv://your_username:your_password@cluster0.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=bhiv_db

# JWT Authentication (REQUIRED)
JWT_SECRET_KEY=your-super-secure-jwt-secret-key-at-least-32-characters-long
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# External Services (Optional)
SOHUM_MCP_URL=https://ai-rule-api-w7z5.onrender.com
RANJEET_RL_URL=https://land-utilization-rl.onrender.com

# AI/ML API Keys (Optional - set only what you use)
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
TRIPO_API_KEY=your_tripo_api_key_here
MESHY_API_KEY=your_meshy_api_key_here
HUGGINGFACE_API_KEY=your_huggingface_token_here

# Yotta Configuration (Optional)
YOTTA_API_KEY=your_yotta_api_key_here
YOTTA_URL=https://api.yotta.ai/v1/inference

# Monitoring (Optional)
SENTRY_DSN=your_sentry_dsn_here
ENABLE_METRICS=true

# Demo Credentials
DEMO_MODE=false
DEMO_USERNAME=admin
DEMO_PASSWORD=change_me_if_demo_enabled
