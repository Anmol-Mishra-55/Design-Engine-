# ============================================================================
# BHIV Design Engine API — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values.
# DO NOT commit .env to version control.
# ============================================================================

# ============================================================================
# APPLICATION
# ============================================================================
APP_NAME=Design Engine API
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000

# ============================================================================
# MONGODB (PRIMARY DATABASE)
# ============================================================================
# Production: use MongoDB Atlas connection string
# Development: use local MongoDB or Atlas free tier
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=bhiv_db
DB_POOL_SIZE=20
DB_MAX_POOL_SIZE=50

# ============================================================================
# BUCKET STORAGE SERVICE
# ============================================================================
# Append-only artifact storage — all GLB/STL/STEP/spec outputs go here.
# Contact: Siddhesh (bucket service owner)
BUCKET_URL=https://bhiv-bucket.onrender.com

# Storage bucket names (used as path prefixes inside the bucket service)
STORAGE_BUCKET_FILES=files
STORAGE_BUCKET_PREVIEWS=previews
STORAGE_BUCKET_GEOMETRY=geometry
STORAGE_BUCKET_COMPLIANCE=compliance

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me-must-be-at-least-32-characters-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# ============================================================================
# CORE INTERNAL TOKEN
# ============================================================================
# Blocks direct calls to /api/v1/generate (Phase 3 enforcement).
# Must be overridden in production.
CORE_INTERNAL_TOKEN=bhiv-core-internal-token-change-in-prod

# ============================================================================
# PUBLIC API URL
# ============================================================================
# Used to construct download_urls returned to clients.
# Set to the deployed service URL in production.
PUBLIC_API_URL=http://localhost:8000

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================

# Sohum MCP Compliance System (contact: Sohum)
SOHUM_MCP_URL=https://ai-rule-api-w7z5.onrender.com
SOHUM_API_KEY=

# Ranjeet Land Utilization RL System (contact: Ranjeet)
RANJEET_RL_URL=https://land-utilization-rl.onrender.com
RANJEET_API_KEY=

# ============================================================================
# 3D GENERATION (OPTIONAL AI PROVIDERS)
# ============================================================================
# If not set, system falls back to geometry_generator_real (always available).
MESHY_API_KEY=
TRIPO_API_KEY=
HUGGINGFACE_API_KEY=

# ============================================================================
# LANGUAGE MODEL (OPTIONAL)
# ============================================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LM_PROVIDER=local

# ============================================================================
# REDIS CACHING (OPTIONAL)
# ============================================================================
# System works without Redis. Health check reports status=not_configured.
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# MONITORING
# ============================================================================
# Sentry error tracking (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

LOG_LEVEL=INFO
LOG_FILE=logs/bhiv.log
METRICS_ENABLED=true

# ============================================================================
# CORS
# ============================================================================
# Comma-separated list of allowed origins
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
CORS_CREDENTIALS=true

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ============================================================================
# MULTI-CITY
# ============================================================================
SUPPORTED_CITIES=Mumbai,Pune,Ahmedabad,Nashik
DEFAULT_CITY=Mumbai

# ============================================================================
# DEMO MODE
# ============================================================================
# Set DEMO_MODE=true to disable Swagger/OpenAPI docs in production.
DEMO_MODE=false
