# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/backend_db

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Security
JWT_SECRET_KEY=your-secret-key-here

# External Services
SENTRY_DSN=your-sentry-dsn
OPENAI_API_KEY=your-openai-key

# Environment
ENVIRONMENT=production
DEBUG=false

# Public API URL (used to build download_urls in responses)
# Set to the deployed service URL, e.g. https://bhiv-backend.onrender.com
PUBLIC_API_URL=https://bhiv-backend.onrender.com

# Yotta Configuration (optional)
YOTTA_API_KEY=your-yotta-key
YOTTA_URL=https://api.yotta.com
